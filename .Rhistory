"a =", round(a_true, 3),
"\\alpha =", round(alpha_true, 3),
",\\; \\gamma =", round(gamma_true, 3),
"$"
)),
hjust = 1.1, vjust = 1.1,
size = 4,
fill = "white") +
theme_minimal() +
theme(legend.position = "none")
df_boxplot_alpha <- data.frame(matrix_alpha_hat_n)
colnames(df_boxplot_alpha) <- c("n = 1000", "n = 5000", "n = 10000")
df_boxplot_alpha_long <- reshape2::melt(df_boxplot_alpha)
boxplot_alpha <- ggplot(df_boxplot_alpha_long, aes(x = variable, y = value, fill = variable)) +
geom_boxplot() +
geom_hline(yintercept = alpha_true,
linetype = "dotted",
color = "red",
linewidth = 1) +
labs(x = "", y = expression(hat(alpha))) +
scale_x_discrete(labels = c(
paste0("n = 1000\n alpha Prop. rej. t=", proportion_rejection_alpha_t[1],"\n Prop. rej. Kendall=", proportion_rejection_kendall[1],"\n Prop. rej. Spearman=", proportion_rejection_spearman[1]),
paste0("n = 5000\n alpha Prop. rej. t=", proportion_rejection_alpha_t[2],"\n Prop. rej. Kendall=", proportion_rejection_kendall[2],"\n Prop. rej. Spearman=", proportion_rejection_spearman[2]),
paste0("n = 10000\n alpha Prop. rej. t=", proportion_rejection_alpha_t[3],"\n Prop. rej. Kendall=", proportion_rejection_kendall[3],"\n Prop. rej. Spearman=", proportion_rejection_spearman[3])
))+
annotate("label",
x = Inf, y = Inf,
label = TeX(paste0(
"$",
"\\alpha_0=", round(alpha0, 3),
",\\; \\alpha_1=", round(alpha1, 3),
", \\;",
"\\lambda_0=", round(lambda0, 3),
",\\; \\lambda_1=", round(lambda1, 3),
", \\;",
"\\Pi_0=", pi0,
",\\; d=", d,
" \\; | \\;  ",
"a =", round(a_true, 3),
"\\alpha =", round(alpha_true, 3),
",\\; \\gamma =", round(gamma_true, 3),
"$"
)),
hjust = 1.1, vjust = 1.1,
size = 4,
fill = "white") +
theme_minimal() +
theme(legend.position = "none")
g <- arrangeGrob(boxplot_a,boxplot_alpha, ncol=2)
ggsave(filename = paste0("C:/Users/Nathan Huet/project e-risk/figures/montecarlo/Gamma2/without_gamma/boxplot_Gamma_d_",d,
"_alpha0_",alpha0 ,"_alpha1_",alpha1,
"_lambda0_",lambda0 ,"_lambda1_",lambda1,
"_pi0_",pi0,
".png"),
plot = g,
width = 3300 / 180,
height = 1060 / 180,
dpi = 180,
units = "in",
bg = 'white')
}
}
}
